--- !u!114 &922490755
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 922490753}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\xDCdv\xF6z\xF6llek, K\xF3dostroml\xF3! Olvasd el figyelmesen a j\xE1t\xE9k
    m\u0171k\xF6d\xE9s\xE9t!\nA c\xE9lod az ellens\xE9ges torony lerombol\xE1sa a
    lehet\u0151 legr\xF6videbb id\u0151 alatt. Sereget a programoz\xE1si feladatok
    helyes megold\xE1s\xE1val toborozhatsz.\n\xDCgyelj a pontoss\xE1gra: be\xE9p\xEDtett
    k\xF3dkieg\xE9sz\xEDt\u0151 hi\xE1ny\xE1ban a helyes szintaktik\xE1ra \xE9s a
    pontos elnevez\xE9sekre neked kell figyelned! V\xE1ltoz\xF3kn\xE1l az \"\xE1ltal\xE1nos\"
    megold\xE1sok helyett mindig a konkr\xE9t, tanult t\xEDpusokat (pl. int, string,
    double) haszn\xE1ld!\nA feladatok k\xF6z\xF6tt a fels\u0151 gombokkal (F1, F2...)
    l\xE9pkedhetsz. A Teszt gombbal ellen\u0151rizheted a k\xF3dod: a rendszer SIKER!
    vagy HIBA! \xFCzenettel (\xE9s hibak\xF3ddal) v\xE1laszol. Ha elfelejten\xE9d
    k\xF3dol\xE1s k\xF6zben, hogy mi volt a pontos feladat, az Inf\xF3 gomb mindig
    seg\xEDt!\nA START gombbal indul a csata! A harcba csak a sikeresen megoldott
    feladatok\xE9rt kapott katon\xE1k k\xEDs\xE9rnek el, ezen ut\xF3lag m\xE1r csak
    a szint \xFAjrakezd\xE9s\xE9vel v\xE1ltoztathatsz.\n\nJ\xF3 sz\xF3rakoz\xE1st
    \xE9s sikeres k\xF3dol\xE1st!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
