  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\xDCdv\xF6z\xF6llek k\xF3d ostroml\xF3! Ebben a le\xEDr\xE1sban benne
    van, hogy hogyan m\u0171k\xF6dik a j\xE1t\xE9k, amit j\xE1tszani fogsz. Olvasd
    el figyelmesen!\nA j\xE1t\xE9k c\xE9lja az, hogy lerombold az ellenf\xE9l torny\xE1t
    a lehet\u0151 legkevesebb id\u0151 alatt, ehhez katon\xE1kra lesz sz\xFCks\xE9ged.
    Katon\xE1kat helyesen megoldott k\xF3dol\xE1si feladatokkal szerezhetsz.\nFigyelj,
    hogy a k\xF3dodat pontosan \xEDrd, mivel ebben a j\xE1t\xE9kban nincs be\xE9p\xEDtett
    k\xF3dkieg\xE9sz\xEDt\u0151, ez\xE9rt mindent neked kell le\xEDrnod. V\xE1ltoz\xF3kat
    a var el\u0151taggal tudsz l\xE9trehozni. Mindig j\xF3l olvasd el a feladat sz\xF6veg\xE9t
    \xE9s pontos v\xE1ltoz\xF3 neveket haszn\xE1lj.\nA Teszt gombbal tudod tesztelni,
    hogy helyes e a k\xF3dod, ha igen, akkor SIKER! feliratot fogsz kapni, ha nem,
    akkor HIBA! feliratot \xE9s egy hibak\xF3dot.\nFel\xFCl az F1, F2 ... gombokkal
    tudsz l\xE9pkedni a szint feladatai k\xF6z\xF6tt, minden szint megold\xE1sa plusz
    aj\xE1nd\xE9kot, katon\xE1t jelent. \nA START gomb lenyom\xE1s\xE1val elindul
    a j\xE1t\xE9k \xE9s csak a megoldott feladatok katon\xE1it kapod meg, ezt ut\xE1na
    nem tudod megv\xE1ltoztatni, csak ha a teljes szintet \xFAjra kezded!\nJ\xF3
    sz\xF3rakoz\xE1st!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
